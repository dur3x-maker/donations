APP_ENV=development

POSTGRES_DB=donations
POSTGRES_USER=donations
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://donations:change-me@postgres:5432/donations

JWT_SECRET_KEY=replace-with-a-long-random-secret
BACKEND_CORS_ORIGINS=http://localhost:3000
TRUSTED_WS_ORIGINS=http://localhost:3000
RATE_LIMIT_ENABLED=true
WS_MAX_CONNECTIONS_PER_IP=20
# Public origin from which the browser can load the persistent /uploads volume.
DEMO_PUBLIC_BASE_URL=http://localhost:8000
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
FRONTEND_PUBLIC_URL=http://localhost:3000
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

NEXT_PUBLIC_API_URL=http://localhost:8000
INTERNAL_API_URL=http://backend:8000
